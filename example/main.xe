
a: array = [1, 2, "Hello"];
a.pushfront(3);                 # 3, 1, 2, "Hello"
a.pushback("Xero");             # 3, 1, 2, "Hello", "Xero"
a.insert(2, 4);                 # 3, 1, 4, 2, "Hello", "Xero"

println("test1");
for (x in a) { println(x); }

println("test2");
for (x in a[1..=3]) { println(x); }     # 1, 4, 2

println("test3");
for (x in a[1..3]) { println(x); }      # 1, 4

println("test4");
for (x in a[1..=a[2]]) { println(x); }  # 1, 4, 2, "Hello"
