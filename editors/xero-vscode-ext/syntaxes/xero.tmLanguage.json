{
    "scopeName": "source.xero",
    "name": "Xero",
    "patterns": [
        { "include": "#comments" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#strings" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#types" },
        { "include": "#functions" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "include": "#blockComment" },
                { "include": "#lineComment" }
            ]
        },
        "blockComment": {
            "name": "comment.block.xero",
            "begin": "##",
            "end": "##"
        },
        "lineComment": {
            "name": "comment.line.number-sign.xero",
            "match": "#.*"
        },
        "numbers": {
            "name": "constant.numeric.xero",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "booleans": {
            "name": "constant.language.boolean.xero",
            "match": "\\b(true|false)\\b"
        },
        "strings": {
            "name": "string.quoted.double.xero",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.xero",
                    "match": "\\\\."
                }
            ]
        },
        "operators": {
            "name": "keyword.operator.xero",
            "match": "[+\\-*/]"
        },
        "punctuation": {
            "name": "punctuation.xero",
            "match": "[:;=(),.]"
        },
        "types": {
            "name": "storage.type.xero",
            "match": "\\b(u?i(?:8|16|32|64)|f(?:32|64)|bool|string)\\b"
        },
        "functions": {
            "name": "support.function.builtin.xero",
            "match": "\\b(print|println)\\b"
        }
    }
}